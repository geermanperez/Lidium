# =============================================================================
# LatinMS v111 (Lidium) — Variables de entorno
# Copiar como .env y completar los valores reales.
# NUNCA commitear el archivo .env al repositorio.
# =============================================================================

# --- Base de datos MySQL ---
DB_HOST=db
DB_PORT=3306
DB_NAME=v111
DB_USER=latinms
DB_PASSWORD=CHANGE_ME

# Contrasena del usuario root de MySQL (solo para el contenedor db)
MYSQL_ROOT_PASSWORD=CHANGE_ME

# --- Puertos del servidor MapleStory ---
LOGIN_PORT=9484
CHANNEL_PORT=8585
CASHSHOP_PORT=9494

# --- JVM ---
# Ajustar segun la RAM disponible en el servidor.
# Minimo recomendado: 1G heap, maximo 2G para 3GB de RAM total del host.
JAVA_OPTS=-Xms1G -Xmx2G

# --- Zona horaria ---
TZ=America/Argentina/Catamarca

# --- Interfaz de red del channel server ---
# En Docker debe ser 0.0.0.0 para aceptar conexiones externas.
# En desarrollo local puede ser 127.0.0.1.
CHANNEL_INTERFACE=0.0.0.0

# --- IP publica del servidor (usada por el cliente MapleStory para conectarse) ---
# Debe ser una IPv4 publica (el protocolo v111 no admite un nombre de dominio).
SERVER_PUBLIC_IP=72.60.154.185
